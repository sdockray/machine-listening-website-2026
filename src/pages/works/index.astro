---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { extractFirstMarkdownImage } from '../../lib/content-images';
import { resolveMediaUrl } from '../../lib/media-url';

const works = (await getCollection('works'))
  .filter((entry) => !entry.data.hideFromIndex)
  .sort((a, b) => {
    const priorityDiff = (b.data.priority ?? 1) - (a.data.priority ?? 1);
    if (priorityDiff !== 0) return priorityDiff;

    const yearA = a.data.year ?? 0;
    const yearB = b.data.year ?? 0;
    if (yearB !== yearA) return yearB - yearA;

    return a.data.title.localeCompare(b.data.title);
  });

const getListingImage = (entry: (typeof works)[number]) => resolveMediaUrl(entry.data.coverImage || extractFirstMarkdownImage(entry.body || ''));
---
<BaseLayout title="Works">
  <h1>Works</h1>
  <ul class="collection-grid">
    {works.map((work) => {
      const listingImage = getListingImage(work);
      return (
        <li class="collection-card">
          <a href={`./${work.id}/`}>
            {listingImage && (
              <img src={listingImage} alt={work.data.title} loading="lazy" />
            )}
            <h2>{work.data.title}</h2>
            <p class="collection-meta">
              {work.data.type && work.data.type.length > 0 && <span style="text-transform: capitalize;">{work.data.type.join(', ')}</span>}
              {work.data.type && work.data.type.length > 0 && work.data.year && <span> &middot; </span>}
              {work.data.year && <span>{work.data.year}{work.data.endYear ? `–${work.data.endYear}` : ''}</span>}
            </p>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
