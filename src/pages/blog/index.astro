---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

// Sort by date descending
allPosts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

const baseUrl = import.meta.env.BASE_URL;
const normalizedBaseUrl = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBaseUrl}${path.replace(/^\//, '')}`;
---
<BaseLayout title="Blog">
  <h1>Blog</h1>
  
  <ul class="collection-grid">
    {allPosts.map((post) => {
      const categoryPath = post.data.category ? `${post.data.category}/` : '';
      return (
        <li class="collection-card">
          <a href={withBase(`/blog/${categoryPath}${post.id}/`)}>
            {post.data.coverImage && (
              <img src={withBase(post.data.coverImage)} alt="" loading="lazy" />
            )}
            <h2>{post.data.title}</h2>
            {post.data.category && (
              <p class="collection-meta">Category: {post.data.category}</p>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
