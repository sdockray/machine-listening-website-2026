---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import '../styles/skins.css';

interface Props {
  title: string;
  skin?: string;
}

const { title, skin } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const normalizedBaseUrl = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => `${normalizedBaseUrl}${path.replace(/^\//, '')}`;

const NAV_LINKS = [
  { label: 'People', href: withBase('/people/') },
  { label: 'Works', href: withBase('/works/') },
  { label: 'Performances', href: withBase('/performances/') },
  { label: 'Curation', href: withBase('/curation/') },
  { label: 'Software', href: withBase('/software/') },
  { label: 'Curriculum', href: withBase('/curriculum/') },
  { label: 'Texts', href: withBase('/texts/') },
  { label: 'Interviews', href: withBase('/interviews/') },
  { label: 'Events', href: withBase('/events/') },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Machine Listening</title>
  </head>
  <body class={skin ? `skin-${skin}` : ''}>
    <header class="site-header">
      <a href={withBase('/')} class="site-title">Machine Listening</a>
      <nav class="site-nav">
        <ul>
          {NAV_LINKS.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p class="acknowledgement">
        This project takes place online, and across multiple unceded Indigenous Lands.
        We acknowledge the people of the Kulin Nation as the custodians of the lands
        on which we work. We pay our respects to Indigenous Elders, past and present.
      </p>
      <div class="footer-links">
        <a href={withBase('/complaints/')}>Complaints</a>
        <a href={withBase('/terms-and-conditions/')}>Terms and Conditions</a>
        <a href="mailto:machinelistening2020@gmail.com">Contact</a>
        <a href="https://www.instagram.com/machinelistening/">Instagram</a>
      </div>
    </footer>
  </body>
</html>
